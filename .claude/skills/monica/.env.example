# Monica CRM API credentials — copy to ~/.config/monica-api/.env (chmod 600).
# Do NOT keep a real .env inside this repo; it is gitignored as a safety net only.
#
# Get a token: your Monica instance → Settings → API → Create Personal Access Token.
# Works with any Monica v4.x instance (self-hosted or app.monicahq.com).

MONICA_API_URL=https://your-monica-instance.example.com/api
MONICA_API_TOKEN=your-personal-access-token

# Optional: if your self-hosted instance uses a self-signed certificate, point this
# at your CA bundle (TLS verification stays on — do not disable it).
#MONICA_API_CA_BUNDLE=/path/to/your-ca.pem
